# Example environment file for development
# Copy this to .env and modify values as needed

# Application Configuration
APP_NAME=talkhead
NODE_ENV=development
PORT=9000
BACKEND_BASE_URL=http://localhost:9000

# CORS (comma-separated list of allowed origins)
# IMPORTANT: If left empty, ALL cross-origin requests are DENIED (fail-closed).
# Example: http://localhost:3000,https://talkhead.app
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Auth cookie settings (refresh_token cookie)
#
# AUTH_COOKIE_SAMESITE:
# - lax    -> Use when frontend + API are same-site (same main domain, different subdomains like app.example.com + api.example.com).
#            Also the best default for local HTTP development.
# - none   -> Use when frontend + API are cross-site (example: http://localhost:3000 calling https://api.example.com).
#            Requires AUTH_COOKIE_SECURE=true and HTTPS (browsers reject SameSite=None without Secure).
# - strict -> Rare; usually breaks common auth flows. Use only if you understand the impact.
#
# AUTH_COOKIE_SECURE:
# - false  -> Local HTTP only (localhost).
# - true   -> Required for HTTPS domains and for SameSite=none.
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false

# Database Configuration
MONGO_URI=mongodb://localhost:27017/talkhead

# JWT Configuration
JWT_ACCESS_TOKEN_SECRET=your-access-token-secret
JWT_REFRESH_TOKEN_SECRET=your-refresh-token-secret
JWT_ACCESS_TOKEN_EXPIRE_IN=15m
JWT_REFRESH_TOKEN_EXPIRE_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=admin

# Email Configuration
ADMIN_CONTACT_EMAIL=admin@example.com
RESEND_API_KEY=your-resend-api-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudflare R2 Configuration
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_SECRET_ACCESS_KEY=your-r2-secret-access-key
CLOUDFLARE_BUCKET_NAME=your-r2-bucket-name
CLOUDFLARE_REGION=auto
CLOUDFLARE_CUSTOM_DOMAIN=your-custom-domain.com

# Frontend URLs
FRONTEND_VERIFY_PAGE_URL=http://localhost:3000/verify-email
FRONTEND_RESET_PAGE_URL=http://localhost:3000/reset-password

# Application Logging (optional — defaults shown)
# APPLICATION_LOG_LEVEL=debug
# APPLICATION_LOG_ERROR_LEVEL=error
# APPLICATION_LOG_DIR=../application-logs
# APPLICATION_LOG_MAX_FILES=15d
# APPLICATION_LOG_MAX_SIZE=20m

# Rate limiting (optional — defaults shown). windowMs in milliseconds.
# Global = blanket /api/v1 cap · Auth = login brute-force · Email = email-send abuse
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000   # 15 min
# RATE_LIMIT_GLOBAL_MAX=100
# RATE_LIMIT_AUTH_WINDOW_MS=900000     # 15 min
# RATE_LIMIT_AUTH_MAX=5
# RATE_LIMIT_EMAIL_WINDOW_MS=3600000   # 1 hour
# RATE_LIMIT_EMAIL_MAX=3
