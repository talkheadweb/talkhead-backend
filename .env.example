# =============================================================================
# Talkhead Backend — environment variable reference
# =============================================================================
# Copy this file to .env and fill in the real values.
# Variables marked (required) must be set — the server crashes at startup
# without them (Zod validation). Variables marked (optional) have defaults.
# =============================================================================


# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=talkhead backend
NODE_ENV=development          # development | production
PORT=9000
BACKEND_BASE_URL=http://localhost:9000


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# IMPORTANT: If left empty, ALL cross-origin requests are DENIED (fail-closed).
# Use * to allow all origins in development (not recommended for production).
# Example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ── Auth cookie (refresh_token) ───────────────────────────────────────────────
#
# AUTH_COOKIE_SAMESITE:
#   lax    → Same-origin or same-site HTTP requests only. Good for local dev.
#   none   → Required when frontend and backend are on DIFFERENT subdomains
#             (e.g. demo.talkhead.ai + dev-api.talkhead.ai). Socket.io connects
#             directly from the browser cross-origin, so Lax blocks the cookies.
#             Requires AUTH_COOKIE_SECURE=true — browsers reject None without Secure.
#   strict → Rarely useful; breaks OAuth redirect flows. Avoid.
#
# AUTH_COOKIE_SECURE:
#   false → Local HTTP only (localhost).
#   true  → Required for HTTPS and for SameSite=none.
#
# AUTH_COOKIE_DOMAIN:
#   Leave unset for local development.
#   Set to ".talkhead.ai" (leading dot = all subdomains) when frontend and API
#   are on different subdomains. The Next.js proxy sets cookies under demo.talkhead.ai;
#   without a shared domain the browser will NOT send those cookies on direct
#   cross-origin requests such as the Socket.io WebSocket handshake.
#   The leading dot is required — "talkhead.ai" covers only the apex, not subdomains.
#
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_DOMAIN=.talkhead.ai   # uncomment for deployed subdomain environments


# ── Database ──────────────────────────────────────────────────────────────────
# When running via Docker Compose, use the service name as the host:
#   MONGO_URI=mongodb://${MONGO_ROOT_USERNAME}:${MONGO_ROOT_PASSWORD}@mongo-server:27017/${MONGO_DB_NAME}?authSource=admin
# For local development without Docker:
#   MONGO_URI=mongodb://localhost:27017/talkhead-backend
MONGO_URI=mongodb://localhost:27017/talkhead-backend     # (required)

# MongoDB credentials — used by the mongo-server Docker Compose service.
# Must match the values embedded in MONGO_URI above when running in Docker.
MONGO_ROOT_USERNAME=admin                                # (required for Docker)
MONGO_ROOT_PASSWORD=changeme                             # (required for Docker — use a strong password in production)
MONGO_DB_NAME=talkhead-backend                           # (required for Docker)

# MongoDB memory tuning (Docker Compose only)
#
# MONGO_WIREDTIGER_CACHE_GB — how much RAM MongoDB uses as a read/write cache
#   (hot indexes + documents). Your actual data lives on DISK regardless of
#   this value — the cache only affects query speed, not storage capacity.
#   Rule of thumb: ~50% of RAM you want to give MongoDB, minimum 0.25.
#   Default: 0.5 (512 MB)
# MONGO_MEMORY_LIMIT — hard Docker ceiling for the entire mongod process.
#   Must be larger than MONGO_WIREDTIGER_CACHE_GB × 1024 MB + ~200 MB overhead.
#   Default: 700M
# MONGO_MEMORY_RESERVATION — soft scheduling hint for Docker Swarm/cluster.
#   Not a cap — container can grow up to MONGO_MEMORY_LIMIT.
#   Default: 128M
#
# MONGO_WIREDTIGER_CACHE_GB=0.5
# MONGO_MEMORY_LIMIT=700M
# MONGO_MEMORY_RESERVATION=128M


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost       # (required)
REDIS_PORT=6379
REDIS_PASSWORD=admin       # (required)


# ── JWT ───────────────────────────────────────────────────────────────────────
# Use long, random strings (32+ chars). Generate with: openssl rand -hex 32
JWT_ACCESS_TOKEN_SECRET=replace-with-a-random-secret-min-32-chars     # (required)
JWT_REFRESH_TOKEN_SECRET=replace-with-a-different-random-secret-32ch  # (required)
JWT_ACCESS_TOKEN_EXPIRE_IN=15m     # short-lived — e.g. 15m, 1h
JWT_REFRESH_TOKEN_EXPIRE_IN=7d     # long-lived  — e.g. 7d, 30d


# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12     # 12 is the production minimum; lower only in test (use 1)


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxx          # (required)
ADMIN_CONTACT_EMAIL=no-reply@example.com  # Sender address shown to recipients


# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# Create a bucket + API token at https://dash.cloudflare.com → R2.
CLOUDFLARE_ACCOUNT_ID=your-account-id          # (required)
CLOUDFLARE_ACCESS_KEY_ID=your-r2-access-key    # (required)
CLOUDFLARE_SECRET_ACCESS_KEY=your-r2-secret    # (required)
CLOUDFLARE_BUCKET_NAME=your-bucket-name        # (required)
CLOUDFLARE_REGION=auto                         # always "auto" for R2
# CLOUDFLARE_CUSTOM_DOMAIN=cdn.example.com     # (optional) public CDN domain for the bucket


# ── Frontend URLs ─────────────────────────────────────────────────────────────
# Used to build links in transactional emails and to redirect after OAuth.
FRONTEND_VERIFY_PAGE_URL=http://localhost:3000/verify-email
FRONTEND_RESET_PAGE_URL=http://localhost:3000/reset-password

# Fallback redirect target after social login (used when the frontend does not
# pass ?origin= to /auth/social/google). Set to your primary production frontend.
# When ?origin= IS passed, this value is ignored — the dynamic origin takes priority.
# Required only when at least one OAuth provider (Google, GitHub, …) is configured.
# FRONTEND_SOCIAL_CALLBACK_URL=https://demo.talkhead.ai/auth/callback


# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI must be: {BACKEND_BASE_URL}/api/v1/auth/social/google/callback
#
# If these are not set, the /auth/google routes return 501 Not Implemented.
# Adding more providers (GitHub, etc.) follows the same pattern — see CLAUDE.md.
#
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret


# ── Application logging (optional — defaults shown) ───────────────────────────
# APPLICATION_LOG_LEVEL=debug          # debug | info | warn | error | silly
# APPLICATION_LOG_ERROR_LEVEL=error    # error | silly (minimum level for error log file)
# APPLICATION_LOG_DIR=../application-logs
# APPLICATION_LOG_MAX_FILES=15d        # rotate after 15 days
# APPLICATION_LOG_MAX_SIZE=20m         # rotate after 20 MB


# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
# windowMs in milliseconds. Limits are per-IP (email routes: per IP+email).
#
# Global → blanket cap on all /api/v1 routes.
#   NOTE: the global limiter is enforced in PRODUCTION only (NODE_ENV=production).
#   It is skipped entirely in development so active API work is never blocked.
#   Auth and email limiters apply in ALL environments.
# RATE_LIMIT_GLOBAL_WINDOW_MS=60000    # 1 min
# RATE_LIMIT_GLOBAL_MAX=300            # 300 req / 1 min
#
# Auth → login brute-force protection (all environments)
# RATE_LIMIT_AUTH_WINDOW_MS=900000     # 15 min
# RATE_LIMIT_AUTH_MAX=10               # 10 attempts / 15 min
#
# Email → outbound email abuse prevention (all environments)
# RATE_LIMIT_EMAIL_WINDOW_MS=3600000   # 1 hour
# RATE_LIMIT_EMAIL_MAX=5               # 5 requests / hour per IP+email

# ─────────────────────────────────────────────────────────────────────────────
# Queue (BullMQ)
# ─────────────────────────────────────────────────────────────────────────────
QUEUE_API_KEY=your-secret-api-key-here          # shared with external team
QUEUE_EXTERNAL_API_URL=https://jsonplaceholder.typicode.com/posts  # real: Kokoro endpoint; dev: JSONPlaceholder mock
# QUEUE_NAME=main-queue                         # default: main-queue
# QUEUE_CONCURRENCY=1                           # default: 1 (sequential)
