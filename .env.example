# =============================================================================
# talkhead-backend — environment variable reference
# =============================================================================
# Copy this file to .env and fill in the real values.
# Variables marked (required) must be set — the server crashes at startup
# without them (Zod validation). Variables marked (optional) have defaults.
# =============================================================================


# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=talkhead
NODE_ENV=development          # development | production
PORT=9000
BACKEND_BASE_URL=http://localhost:9000


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for cross-origin requests.
# IMPORTANT: If left empty, ALL cross-origin requests are DENIED (fail-closed).
# Use * to allow all origins in development (not recommended for production).
# Example: http://localhost:3000,https://app.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000


# ── Auth cookie (refresh_token) ───────────────────────────────────────────────
#
# AUTH_COOKIE_SAMESITE:
#   lax    → Frontend + API are same-site (same domain, different subdomains).
#             Best default for local HTTP development.
#   none   → Frontend + API are cross-site (e.g. localhost:3000 + api.example.com).
#             Requires AUTH_COOKIE_SECURE=true and HTTPS — browsers reject
#             SameSite=None without Secure.
#   strict → Rarely useful; breaks OAuth redirect flows. Avoid unless intentional.
#
# AUTH_COOKIE_SECURE:
#   false → Local HTTP only (localhost).
#   true  → Required for HTTPS and for SameSite=none.
#
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=false


# ── Database ──────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/talkhead     # (required)


# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost       # (required)
REDIS_PORT=6379
REDIS_PASSWORD=admin       # (required)


# ── JWT ───────────────────────────────────────────────────────────────────────
# Use long, random strings (32+ chars). Generate with: openssl rand -hex 32
JWT_ACCESS_TOKEN_SECRET=replace-with-a-random-secret-min-32-chars     # (required)
JWT_REFRESH_TOKEN_SECRET=replace-with-a-different-random-secret-32ch  # (required)
JWT_ACCESS_TOKEN_EXPIRE_IN=15m     # short-lived — e.g. 15m, 1h
JWT_REFRESH_TOKEN_EXPIRE_IN=7d     # long-lived  — e.g. 7d, 30d


# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12     # 12 is the production minimum; lower only in test (use 1)


# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com and create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxx          # (required)
ADMIN_CONTACT_EMAIL=no-reply@example.com  # Sender address shown to recipients


# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# Create a bucket + API token at https://dash.cloudflare.com → R2.
CLOUDFLARE_ACCOUNT_ID=your-account-id          # (required)
CLOUDFLARE_ACCESS_KEY_ID=your-r2-access-key    # (required)
CLOUDFLARE_SECRET_ACCESS_KEY=your-r2-secret    # (required)
CLOUDFLARE_BUCKET_NAME=your-bucket-name        # (required)
CLOUDFLARE_REGION=auto                         # always "auto" for R2
# CLOUDFLARE_CUSTOM_DOMAIN=cdn.example.com     # (optional) public CDN domain for the bucket


# ── Frontend URLs ─────────────────────────────────────────────────────────────
# Used to build links in transactional emails and to redirect after OAuth.
FRONTEND_VERIFY_PAGE_URL=http://localhost:3000/verify-email
FRONTEND_RESET_PAGE_URL=http://localhost:3000/reset-password

# Where the browser lands after a social login (success: ?token=..., failure: ?error=...).
# Required only when at least one OAuth provider (Google, GitHub, …) is configured.
# The frontend reads the token from the URL and stores it.
# FRONTEND_SOCIAL_CALLBACK_URL=http://localhost:3000/auth/callback


# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials.
# Authorized redirect URI must be: {BACKEND_BASE_URL}/api/v1/auth/google/callback
#
# If these are not set, the /auth/google routes return 501 Not Implemented.
# Adding more providers (GitHub, etc.) follows the same pattern — see CLAUDE.md.
#
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret


# ── Application logging (optional — defaults shown) ───────────────────────────
# APPLICATION_LOG_LEVEL=debug          # debug | info | warn | error | silly
# APPLICATION_LOG_ERROR_LEVEL=error    # error | silly (minimum level for error log file)
# APPLICATION_LOG_DIR=../application-logs
# APPLICATION_LOG_MAX_FILES=15d        # rotate after 15 days
# APPLICATION_LOG_MAX_SIZE=20m         # rotate after 20 MB


# ── Rate limiting (optional — defaults shown) ─────────────────────────────────
# windowMs in milliseconds. Limits are per-IP (email routes: per IP+email).
#
# Global → blanket cap on all /api/v1 routes
# RATE_LIMIT_GLOBAL_WINDOW_MS=900000   # 15 min
# RATE_LIMIT_GLOBAL_MAX=300            # 300 req / 15 min (~20/min)
#
# Auth → login brute-force protection
# RATE_LIMIT_AUTH_WINDOW_MS=900000     # 15 min
# RATE_LIMIT_AUTH_MAX=10               # 10 attempts / 15 min
#
# Email → outbound email abuse prevention (register, forgot-password, resend-verification)
# RATE_LIMIT_EMAIL_WINDOW_MS=3600000   # 1 hour
# RATE_LIMIT_EMAIL_MAX=5               # 5 requests / hour per IP+email
